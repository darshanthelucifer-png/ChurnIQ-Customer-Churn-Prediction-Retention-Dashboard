!.github/workflows/test.yml

# ──────────────────────────────────────────────────────────────────────────────
# Temporary Files
# ──────────────────────────────────────────────────────────────────────────────

*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej
*.~lock.*

# ──────────────────────────────────────────────────────────────────────────────
# Secrets & Credentials (NEVER COMMIT THESE!)
# ──────────────────────────────────────────────────────────────────────────────

.env
.env.*
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/
config/secrets.json
*.secret

# API Keys
*_API_KEY*
*_SECRET*
*_TOKEN*

# ──────────────────────────────────────────────────────────────────────────────
# Misc Project-Specific
# ──────────────────────────────────────────────────────────────────────────────

# Screenshots (keep folder, ignore large images if needed)
# docs/screenshots/*.png
# !docs/screenshots/placeholder.png

# Notes and drafts
TODO.md
NOTES.md
scratch/
drafts/

# Large files (use Git LFS if needed)
*.zip
*.tar.gz
*.rar
*.7z

# ──────────────────────────────────────────────────────────────────────────────
# Keep These Files (Explicitly NOT Ignored)
# ──────────────────────────────────────────────────────────────────────────────

# Keep empty directories
!.gitkeep

# Keep example env files
!.env.example
!.env.template

# Keep documentation
!README.md
!CHANGELOG.md
!CONTRIBUTING.md
!LICENSE
!docs/

# Keep requirements
!requirements.txt
!package.json
!package-lock.json